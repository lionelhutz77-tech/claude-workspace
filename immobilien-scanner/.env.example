# Immobilien-Scanner .env Template
# Kopiere zu .env und fülle deine Werte aus
# .env ist gitignored!

# GMx SMTP für E-Mail-Versand
GMX_USER=hutz.erkan@gmx.de
# WICHTIG: Verwende dein GMx App-Passwort (nicht dein Hauptpasswort!)
# App-Passwort erstellen: https://www.gmx.de/app-passwort
GMX_APP_PASSWORD=your_gmx_app_password_here

# Groq API (kostenlos)
GROQ_API_KEY=gsk_xxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Proxy (falls benötigt)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
